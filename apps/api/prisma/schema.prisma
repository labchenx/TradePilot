generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportSource {
  IBKR_CSV
  IBKR_EMAIL_PDF
}

enum ImportFileStatus {
  PREVIEWED
  CONFIRMED
  FAILED
}

enum ImportJobStatus {
  PREVIEWED
  SUCCESS
  FAILED
  PARTIAL
}

enum ImportRecordType {
  TRADE
  CASH_FLOW
  CORPORATE_ACTION
  UNRECOGNIZED
}

enum ImportRecordStatus {
  SUCCESS
  DUPLICATE
  UPDATED
  FAILED
}

enum IbkrEventType {
  TRADE_BUY
  TRADE_SELL
  DEPOSIT
  WITHDRAWAL
  DIVIDEND
  PAYMENT_IN_LIEU
  WITHHOLDING_TAX
  DEBIT_INTEREST
  OTHER_FEE
  FX_COMPONENT
  STOCK_GRANT
  STOCK_DIVIDEND
  TRANSFER_IN
  TRANSFER_OUT
  SPLIT
  REVERSE_SPLIT
  ADJUSTMENT
  UNKNOWN
}

enum TradeSide {
  BUY
  SELL
}

enum CashFlowType {
  DEPOSIT
  WITHDRAWAL
}

enum MarketDataProvider {
  YAHOO_FINANCE
  EASTMONEY
}

enum DuplicateStrategy {
  SKIP
  UPDATE_EMPTY_FIELDS
}

enum EmailProvider {
  QQ_MAIL
  NETEASE_163
}

enum EmailConnectionStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum EmailScanRange {
  SCAN_3D
  SCAN_7D
  SCAN_30D
  SCAN_90D
}

enum EmailMessageStatus {
  FOUND
  PARSED
  IMPORTED
  DUPLICATE
  FAILED
  ERROR
}

enum EmailSyncTriggerType {
  MANUAL
  SCHEDULED
}

enum EmailSyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  importFiles               ImportFile[]
  importJobs                ImportJob[]
  importRecords             ImportRecord[]
  transactionEvents         TransactionEvent[]
  cashFlows                 CashFlow[]
  portfolioMonthlySnapshots PortfolioMonthlySnapshot[]
  positionMonthlySnapshots  PositionMonthlySnapshot[]
  settings                  UserSettings?
  symbolMappings            SymbolMapping[]
  emailMessageRecords       EmailMessageRecord[]
  emailSyncJobs             EmailSyncJob[]

  @@map("users")
}

model UserSettings {
  id                                 String                @id @default(cuid())
  userId                             String                @unique
  user                               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketDataProvider                 MarketDataProvider    @default(EASTMONEY)
  enableQuoteCache                   Boolean               @default(true)
  quoteCacheTtlMinutes               Int                   @default(60)
  enableHistoryCache                 Boolean               @default(true)
  defaultImportSource                ImportSource          @default(IBKR_CSV)
  duplicateStrategy                  DuplicateStrategy     @default(UPDATE_EMPTY_FIELDS)
  autoRefreshQuotesAfterImport       Boolean               @default(true)
  autoRegenerateSnapshotsAfterImport Boolean               @default(true)
  autoRecalculateMetricsAfterImport  Boolean               @default(true)
  saveRawData                        Boolean               @default(true)
  emailProvider                      EmailProvider         @default(QQ_MAIL)
  emailAddress                       String?
  emailImapHost                      String?
  emailImapPort                      Int?
  emailImapSecure                    Boolean               @default(true)
  emailAuthSecretEncrypted           String?
  emailConnectionStatus              EmailConnectionStatus @default(DISCONNECTED)
  emailLastTestAt                    DateTime?
  emailLastSyncAt                    DateTime?
  emailLastSyncStatus                EmailSyncJobStatus?
  emailLastSyncErrorMessage          String?
  emailErrorMessage                  String?
  emailDefaultScanRange              EmailScanRange        @default(SCAN_3D)
  emailAutoSyncEnabled               Boolean               @default(true)
  emailSyncTime                      String                @default("07:00")
  emailOnlyIbkrEmails                Boolean               @default(true)
  emailOnlyPdfAttachments            Boolean               @default(true)
  emailMarkAsRead                    Boolean               @default(false)
  createdAt                          DateTime              @default(now())
  updatedAt                          DateTime              @updatedAt

  @@index([userId])
  @@map("user_settings")
}

model EmailMessageRecord {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAccountId   String
  messageId        String
  subject          String
  from             String
  receivedAt       DateTime?
  attachmentNames  Json
  attachmentHashes Json
  status           EmailMessageStatus @default(FOUND)
  errorMessage     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([userId, messageId])
  @@index([userId])
  @@index([emailAccountId])
  @@index([receivedAt])
  @@map("email_message_records")
}

model EmailSyncJob {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailAccountId  String
  triggerType     EmailSyncTriggerType @default(MANUAL)
  jobKey          String?
  status          EmailSyncJobStatus
  startedAt       DateTime           @default(now())
  finishedAt      DateTime?
  scannedCount    Int                @default(0)
  matchedCount    Int                @default(0)
  attachmentCount Int                @default(0)
  parsedTradeCount Int               @default(0)
  newCount        Int                @default(0)
  insertedCount   Int                @default(0)
  duplicateCount  Int                @default(0)
  errorCount      Int                @default(0)
  errorMessage    String?
  warnings        Json?
  createdAt       DateTime           @default(now())

  @@index([userId])
  @@index([emailAccountId])
  @@index([triggerType])
  @@index([status])
  @@index([createdAt])
  @@unique([jobKey])
  @@map("email_sync_jobs")
}

model SymbolMapping {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSymbol String
  targetSymbol String
  provider     MarketDataProvider @default(EASTMONEY)
  note         String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([userId, provider, sourceSymbol])
  @@index([userId])
  @@index([sourceSymbol])
  @@index([targetSymbol])
  @@map("symbol_mappings")
}

model ImportFile {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename          String
  source            ImportSource       @default(IBKR_CSV)
  fileHash          String
  periodStart       DateTime?          @db.Date
  periodEnd         DateTime?          @db.Date
  status            ImportFileStatus   @default(PREVIEWED)
  summary           Json
  previewEvents     Json?
  transactionEvents TransactionEvent[]
  createdAt         DateTime           @default(now())
  confirmedAt       DateTime?

  @@unique([userId, fileHash])
  @@index([userId])
  @@map("import_files")
}

model ImportJob {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  source         ImportSource    @default(IBKR_CSV)
  status         ImportJobStatus @default(PREVIEWED)
  fileNames      Json
  summary        Json
  previewRecords Json?
  startedAt      DateTime        @default(now())
  finishedAt     DateTime?
  totalCount     Int             @default(0)
  successCount   Int             @default(0)
  duplicateCount Int             @default(0)
  updateCount    Int             @default(0)
  failedCount    Int             @default(0)
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  records        ImportRecord[]

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@map("import_jobs")
}

model ImportRecord {
  id             String             @id @default(cuid())
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  importJobId    String
  importJob      ImportJob          @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  recordType     ImportRecordType
  sourceHash     String?
  status         ImportRecordStatus
  rawData        Json?
  normalizedData Json?
  errorMessage   String?
  createdAt      DateTime           @default(now())

  @@index([userId])
  @@index([importJobId])
  @@index([sourceHash])
  @@index([recordType])
  @@map("import_records")
}

model TransactionEvent {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  importFileId       String
  importFile         ImportFile    @relation(fields: [importFileId], references: [id])
  source             ImportSource
  sourceEventHash    String?
  sourceFileName     String
  sourceSection      String
  rawRowIndex        Int
  rawData            Json
  tradeDate          DateTime      @db.Date
  accountId          String
  description        String
  ibkrType           String
  eventType          IbkrEventType
  symbol             String?
  quantity           Decimal?      @db.Decimal(30, 12)
  absQuantity        Decimal?      @db.Decimal(30, 12)
  price              Decimal?      @db.Decimal(30, 12)
  currency           String?
  grossAmount        Decimal       @db.Decimal(30, 12)
  commission         Decimal       @db.Decimal(30, 12)
  netAmount          Decimal       @db.Decimal(30, 12)
  side               TradeSide?
  isTrade            Boolean
  isExternalCashFlow Boolean
  isIncome           Boolean
  isTaxOrFee         Boolean
  createdAt          DateTime      @default(now())

  @@unique([userId, sourceEventHash])
  @@unique([userId, importFileId, rawRowIndex])
  @@index([userId])
  @@index([tradeDate])
  @@index([eventType])
  @@map("transaction_events")
}

model CashFlow {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId  String?
  type       CashFlowType
  amount     Decimal      @db.Decimal(30, 12)
  currency   String
  flowDate   DateTime     @db.Date
  source     String?
  sourceHash String?
  rawData    Json?
  remark     String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([userId, sourceHash])
  @@index([userId])
  @@index([flowDate])
  @@index([type])
  @@map("cash_flows")
}

model MarketQuoteSnapshot {
  id             String   @id @default(cuid())
  symbol         String
  providerSymbol String
  name           String?
  price          Decimal  @db.Decimal(30, 12)
  currency       String
  provider       String
  rawData        Json?
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([symbol, fetchedAt])
  @@index([providerSymbol, fetchedAt])
  @@map("market_quote_snapshots")
}

model PriceHistory {
  id             String   @id @default(cuid())
  symbol         String
  providerSymbol String
  date           DateTime @db.Date
  close          Decimal  @db.Decimal(30, 12)
  adjustedClose  Decimal? @db.Decimal(30, 12)
  currency       String
  source         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([symbol, date, source])
  @@index([symbol, date])
  @@index([providerSymbol, date])
  @@map("price_history")
}

model PortfolioMonthlySnapshot {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId         String
  month             String
  snapshotDate      DateTime @db.Date
  cashBalance       Decimal  @db.Decimal(30, 12)
  stockMarketValue  Decimal? @db.Decimal(30, 12)
  totalAssets       Decimal? @db.Decimal(30, 12)
  netDeposit        Decimal  @db.Decimal(30, 12)
  totalReturn       Decimal? @db.Decimal(30, 12)
  realizedPnl       Decimal  @db.Decimal(30, 12)
  realizedNetIncome Decimal  @db.Decimal(30, 12)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, accountId, month])
  @@index([userId])
  @@index([accountId, snapshotDate])
  @@map("portfolio_monthly_snapshots")
}

model PositionMonthlySnapshot {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  month         String
  symbol        String
  quantity      Decimal  @db.Decimal(30, 12)
  costBasis     Decimal  @db.Decimal(30, 12)
  marketPrice   Decimal? @db.Decimal(30, 12)
  marketValue   Decimal? @db.Decimal(30, 12)
  unrealizedPnl Decimal? @db.Decimal(30, 12)
  currency      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, accountId, month, symbol])
  @@index([userId])
  @@index([accountId, month])
  @@index([symbol, month])
  @@map("position_monthly_snapshots")
}
