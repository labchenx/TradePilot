generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImportSource {
  IBKR_CSV
}

enum ImportFileStatus {
  PREVIEWED
  CONFIRMED
  FAILED
}

enum ImportJobStatus {
  PREVIEWED
  SUCCESS
  FAILED
  PARTIAL
}

enum ImportRecordType {
  TRADE
  CASH_FLOW
  CORPORATE_ACTION
  UNRECOGNIZED
}

enum ImportRecordStatus {
  SUCCESS
  DUPLICATE
  UPDATED
  FAILED
}

enum IbkrEventType {
  TRADE_BUY
  TRADE_SELL
  DEPOSIT
  WITHDRAWAL
  DIVIDEND
  PAYMENT_IN_LIEU
  WITHHOLDING_TAX
  DEBIT_INTEREST
  OTHER_FEE
  FX_COMPONENT
  STOCK_GRANT
  STOCK_DIVIDEND
  TRANSFER_IN
  TRANSFER_OUT
  SPLIT
  REVERSE_SPLIT
  ADJUSTMENT
  UNKNOWN
}

enum TradeSide {
  BUY
  SELL
}

enum CashFlowType {
  DEPOSIT
  WITHDRAWAL
}

model ImportFile {
  id                String              @id @default(cuid())
  filename          String
  source            ImportSource        @default(IBKR_CSV)
  fileHash          String              @unique
  periodStart       DateTime?           @db.Date
  periodEnd         DateTime?           @db.Date
  status            ImportFileStatus    @default(PREVIEWED)
  summary           Json
  previewEvents     Json?
  transactionEvents TransactionEvent[]
  createdAt         DateTime            @default(now())
  confirmedAt       DateTime?

  @@map("import_files")
}

model ImportJob {
  id             String             @id @default(cuid())
  source         ImportSource        @default(IBKR_CSV)
  status         ImportJobStatus     @default(PREVIEWED)
  fileNames      Json
  summary        Json
  previewRecords Json?
  startedAt      DateTime            @default(now())
  finishedAt     DateTime?
  totalCount     Int                 @default(0)
  successCount   Int                 @default(0)
  duplicateCount Int                 @default(0)
  updateCount    Int                 @default(0)
  failedCount    Int                 @default(0)
  errorMessage   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  records        ImportRecord[]

  @@index([createdAt])
  @@index([status])
  @@map("import_jobs")
}

model ImportRecord {
  id             String             @id @default(cuid())
  importJobId    String
  importJob      ImportJob          @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  recordType     ImportRecordType
  sourceHash     String?
  status         ImportRecordStatus
  rawData        Json?
  normalizedData Json?
  errorMessage   String?
  createdAt      DateTime           @default(now())

  @@index([importJobId])
  @@index([sourceHash])
  @@index([recordType])
  @@map("import_records")
}

model TransactionEvent {
  id                 String        @id @default(cuid())
  importFileId       String
  importFile         ImportFile    @relation(fields: [importFileId], references: [id])
  source             ImportSource
  sourceEventHash    String?       @unique
  sourceFileName     String
  sourceSection      String
  rawRowIndex        Int
  rawData            Json
  tradeDate          DateTime      @db.Date
  accountId          String
  description        String
  ibkrType           String
  eventType          IbkrEventType
  symbol             String?
  quantity           Decimal?      @db.Decimal(30, 12)
  absQuantity        Decimal?      @db.Decimal(30, 12)
  price              Decimal?      @db.Decimal(30, 12)
  currency           String?
  grossAmount        Decimal       @db.Decimal(30, 12)
  commission         Decimal       @db.Decimal(30, 12)
  netAmount          Decimal       @db.Decimal(30, 12)
  side               TradeSide?
  isTrade            Boolean
  isExternalCashFlow Boolean
  isIncome           Boolean
  isTaxOrFee         Boolean
  createdAt          DateTime      @default(now())

  @@unique([importFileId, rawRowIndex])
  @@index([tradeDate])
  @@index([eventType])
  @@map("transaction_events")
}

model CashFlow {
  id           String       @id @default(cuid())
  accountId    String?
  type         CashFlowType
  amount       Decimal      @db.Decimal(30, 12)
  currency     String
  flowDate     DateTime     @db.Date
  source       String?
  sourceHash   String?      @unique
  rawData      Json?
  remark       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([flowDate])
  @@index([type])
  @@map("cash_flows")
}

model MarketQuoteSnapshot {
  id             String   @id @default(cuid())
  symbol         String
  providerSymbol String
  name           String?
  price          Decimal  @db.Decimal(30, 12)
  currency       String
  provider       String
  rawData        Json?
  fetchedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([symbol, fetchedAt])
  @@index([providerSymbol, fetchedAt])
  @@map("market_quote_snapshots")
}

model PriceHistory {
  id             String   @id @default(cuid())
  symbol         String
  providerSymbol String
  date           DateTime @db.Date
  close          Decimal  @db.Decimal(30, 12)
  adjustedClose  Decimal? @db.Decimal(30, 12)
  currency       String
  source         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([symbol, date, source])
  @@index([symbol, date])
  @@index([providerSymbol, date])
  @@map("price_history")
}

model PortfolioMonthlySnapshot {
  id                String   @id @default(cuid())
  accountId         String
  month             String
  snapshotDate      DateTime @db.Date
  cashBalance       Decimal  @db.Decimal(30, 12)
  stockMarketValue  Decimal? @db.Decimal(30, 12)
  totalAssets       Decimal? @db.Decimal(30, 12)
  netDeposit        Decimal  @db.Decimal(30, 12)
  totalReturn       Decimal? @db.Decimal(30, 12)
  realizedPnl       Decimal  @db.Decimal(30, 12)
  realizedNetIncome Decimal  @db.Decimal(30, 12)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([accountId, month])
  @@index([accountId, snapshotDate])
  @@map("portfolio_monthly_snapshots")
}

model PositionMonthlySnapshot {
  id            String   @id @default(cuid())
  accountId     String
  month         String
  symbol        String
  quantity      Decimal  @db.Decimal(30, 12)
  costBasis     Decimal  @db.Decimal(30, 12)
  marketPrice   Decimal? @db.Decimal(30, 12)
  marketValue   Decimal? @db.Decimal(30, 12)
  unrealizedPnl Decimal? @db.Decimal(30, 12)
  currency      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([accountId, month, symbol])
  @@index([accountId, month])
  @@index([symbol, month])
  @@map("position_monthly_snapshots")
}
